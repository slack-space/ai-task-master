# **** AUTOMATION CONFIGURATION ****
# ANTHROPIC_API_KEY is required. If you are using Ollama set it to any value as it will not be used, but must be present to satisfy the login check in the task scheduler script. 
ANTHROPIC_API_KEY='sk-ant-ollama-12345'
# If you are using ollama, override the base URL and provide a dummy auth token
ANTHROPIC_BASE_URL='http://localhost:11434'
ANTHROPIC_AUTH_TOKEN='ollama'